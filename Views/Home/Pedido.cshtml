@{
    ViewBag.Title = "Home Page";
    Layout = "~/Views/Shared/_WelcomeLayout.cshtml";
}
<style>
    body {
        font-family: Arial, sans-serif;
        margin: 0;
        max-height: 1920px;
        padding: 0;
        background-color: #f5f5f5;
        display: flex;
    }

    .banner {
        width: 1080px;
        height: 140px;
        background: url("https://as1.ftcdn.net/v2/jpg/11/83/61/00/1000_F_1183610030_iUhROCUzBuwVs6SkAk9um8cTY43gNUh8.jpg") center/cover;
        text-align: center;
        padding: 120px 20px;
        color: white;
        font-size: 1.8rem;
        font-weight: bold;
        margin: 0;
        position: fixed;
        top: 0;
        left: 0;
        right: 0;
        z-index: 1;
    }

    /* Barra Lateral */
    .sidebar {
        width: 250px;
        background: #F7F7F7;
        color: #000000;
        padding: 20px;
        position: fixed;
        margin-top: 380px;
        height: 1367px;
        overflow-y: auto;
        box-shadow: 1px 7px 58.3px -2px rgba(0, 0, 0, 0.25);
    }

    .sidebar h2 {
        color: var(--Cinzas-e-Pretos, #463B3B);
        text-align: center;
        font-family: Inter;
        font-size: 20px;
        font-style: normal;
        font-weight: 600;
        line-height: normal;
    }

    .sidebar ul {
        list-style: none;
        justify-content: center;
        padding: 10px;
    }

    .sidebar ul li {
        width: 199px;
        height: 175px;
        padding: 10px;
        margin: 10px 0;
        margin-bottom: 42px;
        background: #FFF;
        text-align: center;
        box-shadow: 0px 4px 23.3px -5px rgba(0, 0, 0, 0.25);
        cursor: pointer;
        border-radius: 30px;
    }

    .sidebar ul li:hover {
        background: #C1D343;
    }

    .sidebar img{
        width: 180px;
        height: 130px;
        object-fit: contain;
    }

    /* Conteúdo Principal */
    .content {
        margin-left: 300px;
        margin-top: 400px;
        width: calc(100% - 250px);
        padding: 20px;
    }

    .menu-header {
        text-align: center;
        font-size: 24px;
        font-weight: bold;
        margin-bottom: 20px;
    }

    .menu-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
        gap: 20px;
    }

    .menu-item {
        background: #fff;
        border-radius: 10px;
        padding: 15px;
        box-shadow: 0px 0px 5px rgba(0, 0, 0, 0.1);
        text-align: center;
        cursor: pointer;
    }

    .menu-item img {
        width: 100%;
        height: 150px;
        object-fit: cover;
        border-radius: 10px;
    }

    .menu-item h3 {
        font-size: 18px;
        margin: 10px 0;
    }

    .menu-item p {
        font-size: 14px;
        color: #666;
    }

    .menu-item .price {
        font-size: 16px;
        font-weight: bold;
        color: #e44d26;
    }

    /* Footer */
    .footer {
        position: fixed;
        bottom: 0;
        width: 1080px;
        height: 195px;
        background: white;
        padding: 20px;
        justify-content: space-between;
        align-items: center;
        box-shadow: 0px -2px 5px rgba(0, 0, 0, 0.1);
    }

    .footer div {
        font-size: 18px;
    }

    .footer button {
        background-color: #e44d26;
        color: white;
        border: none;
        padding: 10px 20px;
        font-size: 16px;
        cursor: pointer;
        border-radius: 5px;
    }

    .footer button:hover {
        background: #d14022;
    }
</style>

<div class="banner">
</div>

