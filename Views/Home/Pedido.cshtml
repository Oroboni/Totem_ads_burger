</div>

<!-- Conteúdo Principal -->
<div class="content" id="content">
    <div class="menu-grid">
        <div class="menu-item" onclick="addToCart(24.00)">
            <img src="https://cdn.pixabay.com/photo/2021/10/11/07/07/burger-6699427_1280.jpg" alt="Burger 404">
            <h3>Burger 404</h3>
            <p>Hambúrguer clássico com queijo derretido e molho especial.</p>
            <p class="price">R$ 24,00</p>
        </div>
        <div class="menu-item" onclick="addToCart(25.00)">
            <img src="https://cdn.pixabay.com/photo/2020/02/20/16/13/burger-4867074_1280.jpg" alt="Full Stack Burger">
